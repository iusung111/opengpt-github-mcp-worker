{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "opengpt-github-mcp-worker",
	"main": "worker/src/index.ts",
	"compatibility_date": "2026-03-10",
	"assets": {
		"directory": "./public",
		"not_found_handling": "none"
	},
	"observability": {
		"enabled": true
	},
	"compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
	"vars": {
		"GITHUB_API_URL": "https://api.github.com",
		"GITHUB_ALLOWED_REPOS": "iusung111/OpenGPT,iusung111/opengpt-github-mcp-worker,iusung111/opengpt-github-mcp-worker-mirror-backup",
		"GITHUB_ALLOWED_WORKFLOWS": "agent-run.yml,pr-merge.yml,cloudflare-live-deploy.yml,cloudflare-self-deploy.yml",
		"GITHUB_ALLOWED_WORKFLOWS_BY_REPO": "{\"iusung111/OpenGPT\":[\"agent-run.yml\",\"pr-merge.yml\",\"cloudflare-live-deploy.yml\",\"opengpt-exec.yml\",\"opengpt-package.yml\"],\"iusung111/opengpt-github-mcp-worker\":[\"cloudflare-self-deploy.yml\",\"gui-capture.yml\",\"opengpt-exec.yml\",\"opengpt-package.yml\"],\"iusung111/opengpt-github-mcp-worker-mirror-backup\":[\"cloudflare-self-deploy.yml\",\"gui-capture.yml\",\"opengpt-exec.yml\",\"opengpt-package.yml\"]}",
		"AGENT_BRANCH_PREFIX": "agent/",
		"DEFAULT_BASE_BRANCH": "main",
		"SELF_REPO_KEY": "iusung111/opengpt-github-mcp-worker",
		"SELF_DEPLOY_WORKFLOW": "cloudflare-self-deploy.yml",
		"SELF_LIVE_URL": "https://opengpt-github-mcp-worker.iusung111.workers.dev",
		"SELF_MIRROR_URL": "https://opengpt-github-mcp-worker-mirror.iusung111.workers.dev",
		"SELF_CURRENT_URL": "https://opengpt-github-mcp-worker.iusung111.workers.dev",
		"SELF_DEFAULT_DEPLOY_TARGET": "mirror",
		"SELF_REQUIRE_MIRROR_FOR_LIVE": "true",
		"MCP_REQUIRE_ACCESS_AUTH": "false",
		"MCP_ALLOWED_EMAILS": "",
		"MCP_ALLOWED_EMAIL_DOMAINS": "",
		"CHATGPT_MCP_AUTH_MODE": "oidc",
		"CHATGPT_MCP_ISSUER": "https://dev-plkp1egugigfyy20.us.auth0.com/",
		"CHATGPT_MCP_AUDIENCE": "https://opengpt-github-mcp-worker,https://dev-plkp1egugigfyy20.us.auth0.com/userinfo",
		"CHATGPT_MCP_JWKS_URL": "https://dev-plkp1egugigfyy20.us.auth0.com/.well-known/jwks.json",
		"CHATGPT_MCP_JWKS_JSON": "",
		"CHATGPT_MCP_ALLOWED_EMAILS": "iusung111@gmail.com",
		"GUI_OIDC_CLIENT_ID": "ZVOPZ3w5zfRTw0brgJdlDLKQ5jxrNpAm",
		"DEFAULT_AUTO_IMPROVE_MAX_CYCLES": "1",
		"WORKING_STALE_AFTER_MS": "600000",
		"REVIEW_STALE_AFTER_MS": "1800000",
		"DISPATCH_DEDUPE_WINDOW_MS": "30000",
		"AUDIT_RETENTION_COUNT": "500",
		"DELIVERY_RETENTION_COUNT": "500",
		"REQUIRE_WEBHOOK_SECRET": "true",
		"GITHUB_APP_ID": "3105333",
		"GITHUB_APP_INSTALLATION_ID": "116782548"
	},
	"durable_objects": {
		"bindings": [
			{
				"name": "JOB_QUEUE",
				"class_name": "JobQueueDurableObject"
			},
			{
				"name": "FILE_UPLOADS",
				"class_name": "UploadSessionDurableObject"
			}
		]
	},
	"migrations": [
		{
			"tag": "v1",
			"new_sqlite_classes": ["JobQueueDurableObject"]
		},
		{
			"tag": "v2",
			"new_sqlite_classes": ["UploadSessionDurableObject"]
		}
	],
	"env": {
		"mirror": {
			"name": "opengpt-github-mcp-worker-mirror",
			"durable_objects": {
				"bindings": [
					{
						"name": "JOB_QUEUE",
						"class_name": "JobQueueDurableObject"
					},
					{
						"name": "FILE_UPLOADS",
						"class_name": "UploadSessionDurableObject"
					}
				]
			},
			"migrations": [
				{
					"tag": "v1",
					"new_sqlite_classes": ["JobQueueDurableObject"]
				},
				{
					"tag": "v2",
					"new_sqlite_classes": ["UploadSessionDurableObject"]
				}
			],
			"vars": {
				"GITHUB_API_URL": "https://api.github.com",
				"GITHUB_ALLOWED_REPOS": "iusung111/OpenGPT,iusung111/opengpt-github-mcp-worker,iusung111/opengpt-github-mcp-worker-mirror-backup",
				"GITHUB_ALLOWED_WORKFLOWS": "agent-run.yml,pr-merge.yml,cloudflare-live-deploy.yml,cloudflare-self-deploy.yml",
				"GITHUB_ALLOWED_WORKFLOWS_BY_REPO": "{\"iusung111/OpenGPT\":[\"agent-run.yml\",\"pr-merge.yml\",\"cloudflare-live-deploy.yml\",\"opengpt-exec.yml\",\"opengpt-package.yml\"],\"iusung111/opengpt-github-mcp-worker\":[\"cloudflare-self-deploy.yml\",\"gui-capture.yml\",\"opengpt-exec.yml\",\"opengpt-package.yml\"],\"iusung111/opengpt-github-mcp-worker-mirror-backup\":[\"cloudflare-self-deploy.yml\",\"gui-capture.yml\",\"opengpt-exec.yml\",\"opengpt-package.yml\"]}",
				"AGENT_BRANCH_PREFIX": "agent/",
				"DEFAULT_BASE_BRANCH": "main",
				"SELF_REPO_KEY": "iusung111/opengpt-github-mcp-worker",
				"SELF_DEPLOY_WORKFLOW": "cloudflare-self-deploy.yml",
				"SELF_LIVE_URL": "https://opengpt-github-mcp-worker.iusung111.workers.dev",
				"SELF_MIRROR_URL": "https://opengpt-github-mcp-worker-mirror.iusung111.workers.dev",
				"SELF_CURRENT_URL": "https://opengpt-github-mcp-worker-mirror.iusung111.workers.dev",
				"SELF_DEFAULT_DEPLOY_TARGET": "mirror",
				"SELF_REQUIRE_MIRROR_FOR_LIVE": "true",
				"MCP_REQUIRE_ACCESS_AUTH": "false",
				"MCP_ALLOWED_EMAILS": "",
				"MCP_ALLOWED_EMAIL_DOMAINS": "",
				"CHATGPT_MCP_AUTH_MODE": "oidc",
				"CHATGPT_MCP_ISSUER": "https://dev-plkp1egugigfyy20.us.auth0.com/",
				"CHATGPT_MCP_AUDIENCE": "https://opengpt-github-mcp-worker,https://dev-plkp1egugigfyy20.us.auth0.com/userinfo",
				"CHATGPT_MCP_JWKS_URL": "https://dev-plkp1egugigfyy20.us.auth0.com/.well-known/jwks.json",
				"CHATGPT_MCP_JWKS_JSON": "",
				"CHATGPT_MCP_ALLOWED_EMAILS": "iusung111@gmail.com",
				"GUI_OIDC_CLIENT_ID": "ZVOPZ3w5zfRTw0brgJdlDLKQ5jxrNpAm",
				"DEFAULT_AUTO_IMPROVE_MAX_CYCLES": "1",
				"WORKING_STALE_AFTER_MS": "600000",
				"REVIEW_STALE_AFTER_MS": "1800000",
				"DISPATCH_DEDUPE_WINDOW_MS": "30000",
				"AUDIT_RETENTION_COUNT": "500",
				"DELIVERY_RETENTION_COUNT": "500",
				"REQUIRE_WEBHOOK_SECRET": "true",
				"GITHUB_APP_ID": "3105333",
				"GITHUB_APP_INSTALLATION_ID": "116782548"
			}
		}
	}
}
